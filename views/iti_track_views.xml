<odoo>
    <!--    action-->
    <record id="iti_track_action" model="ir.actions.act_window">
        <field name="name">Track</field>
        <field name="res_model">iti.track</field>
    </record>

    <!--    tree view-->
    <record id="iti_track_tree_view" model="ir.ui.view">
        <field name="name">track Tree View</field>
        <field name="model">iti.track</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="capacity"/>
                <field name="is_opened"/>
            </tree>
        </field>
    </record>
    <!--    form view-->
    <record id="iti_track_form_view" model="ir.ui.view">
        <field name="name">Track Form View</field>
        <field name="model">iti.track</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <notebook>
                        <page string="Page1">
                            <group string="Personal Information">
                                <field name="name"/>
                                <field name="capacity"/>
                                <field name="is_opened"/>
                                <field name="student_ids">
                                    <tree>
                                        <field name="name"/>
                                    </tree>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem id="iti_track_menu" name="Tracks" parent="iti_data_menu"
              action="iti_track_action" sequence="1"/>
</odoo>